{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FmoDeck",
  "version": "0.1.8",
  "identifier": "com.wh0am1i.fmodeck",
  "build": {
    "beforeDevCommand": "pnpm dev --mode tauri",
    "beforeBuildCommand": "pnpm build --mode tauri",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FmoDeck",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "MIT · based on FmoLogs",
    "category": "Utility",
    "shortDescription": "业余无线电 FMO 日志与控制台",
    "longDescription": "FmoDeck · 业余无线电 FMO 平台的日志与控制台 · 战术 HUD 主题 · FmoLogs 二次开发版本"
  }
}
