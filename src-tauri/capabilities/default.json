{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "FmoDeck 主窗口默认能力：打开外链 + 升级下载到 app cache",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    "fs:default",
    "fs:write-files",
    {
      "identifier": "fs:scope",
      "allow": ["$APPCACHE/**"]
    }
  ]
}
